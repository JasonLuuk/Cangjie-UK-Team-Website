---
import cangjieLogo from "../assets/cangjie-logo.png";

const navItems = [
    { label: "Download", href: "https://cangjie-lang.cn/en/download" },
    { label: "Docs", href: "https://cangjie-lang.cn/en/docs" },
    { label: "Code Repo", href: "https://gitcode.com/Cangjie" },
    { label: "About Team", href: "/about" },
];
---

<header class="site-header">
    <div class="site-header-inner">
        <a href="/" class="brand brand-link">
            Cangjie UK
            <span class="brand-mark">
                <img
                    class="brand-logo"
                    src={cangjieLogo.src}
                    alt="Cangjie Logo"
                    loading="lazy"
                />
            </span>
        </a>
        <nav class="site-nav" aria-label="Primary">
            {
                navItems.map((item) => (
                    <a href={item.href} class="nav-link">
                        {item.label}
                    </a>
                ))
            }
        </nav>
    </div>
</header>
